<style>
    .cm-swatch__thumbnail-container {
      display: grid !important;
      grid-template-columns: repeat(5, minmax(0, 1fr)) !important;
      gap: 0.375rem !important;
      max-width: 100% !important;
      box-sizing: border-box !important;
    }

    @media (min-width: 768px) {
      .cm-swatch__thumbnail-container {
        grid-template-columns: repeat(6, minmax(0, 1fr)) !important;
      }
    }

    @media (min-width: 1024px) {
      #cm-preview {
        height: 750px;
      }
    }

    .cm-swatch__thumbnail-container .cm-swatch__thumbnail {
      min-width: 0 !important;
      width: 100% !important;
      height: auto !important;
      aspect-ratio: 1 / 1 !important;
    }

    .cm-preview-button {
      background-color: #fff !important;
      font-size: 18px !important;
      color: #f16523 !important;
      font-weight: 700 !important;
      height: 60px;
      width: 100% !important;
      border: 1px solid #f16523;
      border-radius: 10px;
    }

    .btn-preview-wrapper {
      display: none;
      position: fixed;
      left: 0;
      bottom: 0;
      width: 100%;
      z-index: 9999;
      text-align: center;
      margin: 0 auto !important;
    }

    @media (max-width: 600px) {
      .cm-product .btn-preview-wrapper{
        display: block;
      }
    }

</style>

<div class="btn-preview-wrapper">
  <button type="button" class="btn-preview button" id="cm-preview-btn">Preview Your Design</button>
</div>

<script>
  window.addEventListener('load', function() {
    if (window.customixText) {
      window.customixText.set("txt:preview_design_title", "Please check the preview carefully");
      window.customixText.set("txt:preview_design_des", "Make sure the below customization is correct to receive your item faster");
    }
  });
</script>
