{% elsif color_check contains "dark heather grey" %}
     #5b5b5b
{% elsif color_check contains "heather grey" %}
     #d5d6db
{% elsif color_check contains "athletic heather" %}
     #acb1a6
{% elsif color_check contains "sport grey" %}
